# ============================================================
# NetServe Telecom — .gitignore
# ============================================================

# ── Environment & Secrets (NEVER commit) ─────────────────────
.env

# ── PHP Dependencies ─────────────────────────────────────────
/vendor/

# ── Razorpay SDK (can be re-downloaded; no need to commit) ───
# Comment this out if you want to commit the SDK instead
# /Razorpay/

# ── PHPMailer (can be re-downloaded) ─────────────────────────
# Comment out if you want to commit PHPMailer
# /PHPMailer/

# ── Uploaded user files ───────────────────────────────────────
/uploads/plans/

# ── Analytics generated output (re-generated by Python) ──────
analytics/*.png
analytics/ml_predictions.json

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# ── Node (if ever added) ─────────────────────────────────────
node_modules/

# ── OS / IDE files ────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
*.log

# ── Temp / backup files ───────────────────────────────────────
*.bak
*.tmp
artel2_backup/
razorpay-sdk.zip

# ── Dev-only seeder (not for production) ─────────────────────
seed-data.php
