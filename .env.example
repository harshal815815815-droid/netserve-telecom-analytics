# ============================================================
# NetServe Telecom — Environment Variables TEMPLATE
# ============================================================
# Copy this file to .env and fill in your own values.
# Never fill in real secrets here — this file IS committed.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=airtel_db

# ── SMTP (Gmail App Password) ─────────────────────────────────
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=your_gmail@gmail.com
SMTP_FROM_NAME=NetServe Service

# ── Razorpay ─────────────────────────────────────────────────
# Get keys at: https://dashboard.razorpay.com → Settings → API Keys
RZP_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RZP_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RZP_CURRENCY=INR
RZP_COMPANY=NetServe Telecom
RZP_LOGO=https://your-domain.com/logo.png

# ── App ──────────────────────────────────────────────────────
APP_NAME=NetServe
APP_ENV=local
